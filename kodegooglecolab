# Proses balasan AI
if len(active_session["messages"]) > 1 and active_session["messages"][-1]["role"] == "user":
    last_user_prompt = active_session["messages"][-1]["content"]

    loading_placeholder = st.empty()
    chat_placeholder = st.empty()
    full_response = ""
